# Postgres aus docker-compose.yml (`just db-up`)
DATABASE_URL=postgres://lm:lm@localhost:5432/leistungsmatrix

# Port des Express-Servers
PORT=3001

# Erlaubter CORS-Origin (Vite-Dev-Server)
FRONTEND_URL=http://localhost:5173

# Legt beim Start ein Dev-Projekt mit festem Teilnehmer-Key TN-DEVKEY an
SEED_DEV=true

# Passwort für die /api/admin-Routen
ADMIN_PASSWORD=change-me

# Für die KI-Analyse (/api/ai)
# Achtung: routes/ai.js sendet den Key aktuell noch nicht mit (fehlender x-api-key-Header)
ANTHROPIC_API_KEY=
